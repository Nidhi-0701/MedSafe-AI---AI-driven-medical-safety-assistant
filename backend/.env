# MedSafe AI Backend – copy to .env and fill in values

# Optional: Google Gemini API key (required for symptom check, prescription analysis, side-effect explanation)
# Paste your key after the = (no quotes, no spaces)
GEMINI_API_KEY=paste_your_gemini_key_here

# Optional: PostgreSQL (if not set, SQLite is used: backend/medsafe.db)
# DATABASE_URL=postgresql://user:password@localhost:5432/medsafe

# Your local PostgreSQL connection (password is URL-encoded: @ -> %40)
DATABASE_URL=postgresql://postgres:Sonu%401234@localhost:5432/medsafe

# Optional: Flask
# SECRET_KEY=your-secret-key
# PORT=5000
# FLASK_DEBUG=true

# Optional: Use EasyOCR instead of Tesseract for prescription OCR
# USE_EASY_OCR=false
